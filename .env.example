# Slack token (User OAuth Token — xoxp-...)
SLACK_BOT_TOKEN=xoxp-...

# Your email address (looked up in Slack to find your submissions)
# If not set, you'll be prompted on first run
USER_EMAIL=

# How far back to scan Slack for submissions
LOOKBACK_DAYS=60

# Nudge settings
NUDGE_DAYS=3                           # Days without emoji before nudging
NUDGE_DM_ONLY=true                     # Send DM summary only (no thread replies)
NUDGE_TRACKER_PATH=.nudge_tracker.json

# Gmail (for email notifications)
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./gmail_token.json
